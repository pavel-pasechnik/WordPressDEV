#: checks/class-bad-things-check.php:44 checks/class-bad-things-check.php:45
msgid "Potential affiliate link detected"
msgstr "Обнаружена потенциальная партнерская ссылка"

#: checks/class-bad-things-check.php:43
msgid "Sharesale affiliate link detected"
msgstr "Обнаружена партнерская ссылка Sharesale"

#: checks/class-admin-menu-check.php:62
msgctxt "function name"
msgid "Themes should not use <strong>%s()</strong>."
msgstr "Темы не должны использовать <strong>%s()</strong>."

#: main.php:198
msgid "Developing with WordPress Forum"
msgstr "Разработка с форумом WordPress"

#: main.php:197
msgid "Theme Handbook"
msgstr "Руководство по созданию тем"

#: main.php:195
msgid "Useful Links"
msgstr "Полезные ссылки"

#: checks/class-customizer-check.php:57
msgid "Every call to the <strong>add_setting()</strong> method needs to have a sanitization callback function passed."
msgstr "Каждый вызов метода <strong>add_setting()</strong> должен содержать переданную коллбэк-функцию санитизации."

#: checks/class-customizer-check.php:57
msgid "Found a Customizer setting called %1$s in %2$s that did not have a sanitization callback function. "
msgstr "Найдена настройка \"Кастомайзера\" под названием %1$s в %2$s, которая не имеет коллбэк-функцию санитизации."

#: checks/class-no-hidden-admin-bar-check.php:65
msgid "The theme is using `#wpadminbar` in %1$s. Hiding the admin bar is not allowed. This warning must be manually checked."
msgstr "Тема использует `#wpadminbar` в %1$s. Скрытие панели администратора не допускается. Это предупреждение необходимо проверить вручную."

#: checks/class-no-hidden-admin-bar-check.php:41
msgid "%1$s Themes are not allowed to hide the admin bar. This warning must be manually checked."
msgstr "Темам %1$s не разрешено скрывать панель администратора. Это предупреждение необходимо проверить вручную."

#: checks/class-escaping-check.php:77 checks/class-escaping-check.php:97
msgid "Found %1$s in %2$s. %3$s. A manual review is needed."
msgstr "Найдено %1$s в %2$s. %3$s. Необходима ручная проверка."

#: checks/class-escaping-check.php:57
msgid "Found %1$s in %2$s. <a href=\"%3$s\" target=\"_blank\">Theme options must be escaped (Opens in a new window).</a>. "
msgstr "Найдено %1$s в %2$s. <a href=\"%3$s\" target=\"_blank\">Опции темы должны быть экранированы (откроется в новом окне).</a>."

#: checks/class-escaping-check.php:43
msgid "get_template_directory_uri() must be escaped when output as part of a link or image source. Use esc_url() for link attributes"
msgstr "get_template_directory_uri() должна быть экранирована при выводе в качестве части ссылки или источника изображения. Используйте esc_url() для атрибутов ссылок"

#: checks/class-escaping-check.php:42
msgid "home_url() must be escaped. Use esc_url() for link attributes"
msgstr "home_url() должен быть экранирован. Используйте esc_url() для атрибутов ссылок"

#: checks/class-escaping-check.php:38
msgid "Only use esc_attr_e() inside HTML attributes. Use esc_html_e() between HTML tags"
msgstr "Используйте esc_attr_e() только внутри атрибутов HTML. Используйте esc_html_e() между тегами HTML"

#: checks/class-escaping-check.php:37
msgid "Only use esc_attr__() inside HTML attributes. Use esc_html__() between HTML tags"
msgstr "Используйте esc_attr__() только внутри атрибутов HTML. Используйте esc_html__() между тегами HTML"

#: checks/class-escaping-check.php:36
msgid "Only use esc_attr() inside HTML attributes. Use esc_html() between HTML tags"
msgstr "Используйте esc_attr() только внутри атрибутов HTML. Используйте esc_html() между тегами HTML"

#: checks/class-escaping-check.php:35
msgid "Use esc_attr() inside HTML attributes, and esc_url() for link attributes"
msgstr "Используйте esc_attr() внутри атрибутов HTML и esc_url() для атрибутов ссылок"

#: checks/class-escaping-check.php:34
msgid "Use esc_attr__() inside HTML attributes, and esc_url() for link attributes"
msgstr "Используйте esc_attr__() внутри атрибутов HTML и esc_url() для атрибутов ссылок"

#: checks/class-escaping-check.php:33
msgid "Use esc_attr_e() inside HTML attributes, and esc_url() for link attributes"
msgstr "Используйте esc_attr_e() внутри атрибутов HTML и esc_url() для атрибутов ссылок"

#: checks/class-non-gpl-check.php:57
msgid "View license (opens in a new window)."
msgstr "Посмотреть лицензию (откроется в новом окне)"

#: checks/class-non-gpl-check.php:54
msgid "Found a reference to %s. Assets from this website does not use a license that is compatible with GPL."
msgstr "Найдена ссылка на %s. Ресурсы с этого веб-сайта не используют лицензию, совместимую с GPL."

#: checks/class-nav-menu-check.php:105
msgid "A menu name is being used for a menu in %1$s. By using menu name, the menu would be required to have the exact same name in the WordPress admin area. Use a theme_location instead."
msgstr "Имя меню используется для меню в %1$s. При использовании имени меню, меню должно иметь точно такое же имя в административной области WordPress. Вместо этого используйте theme_location."

#: checks/class-nav-menu-check.php:89
msgid "A menu without a theme_location was found in %1$s."
msgstr "Меню без theme_location было найдено в %1$s."

#: checks/class-nav-menu-check.php:76
msgid "A menu without a theme_location was found in %1$s. %2$s is used inside wp_nav_menu(). You must manually check if the theme_location is included."
msgstr "Меню без theme_location было найдено в %1$s. %2$s используется внутри wp_nav_menu(). Вы должны вручную проверить, включен ли theme_location."

#: checks/class-underscores-check.php:94
msgid "Found a copy of Underscores. See %1$s. Update the files for your own theme."
msgstr "Найдена копия Underscores. См. %1$s. Обновите файлы для своей темы."

