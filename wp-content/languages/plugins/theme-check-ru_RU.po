msgid "Themes Team"
msgstr "Тематическая группа"

#: checks/class-style-tags-check.php:116
msgid "The tag %s is being used, please remove it from your style.css header. It is only allowed for Block Themes."
msgstr "Используется метка %s, пожалуйста, удалите её из заголовка style.css. Они разрешены только для блочных тем."

#: checks/class-fse-required-files-check.php:46
msgid "Could not find the index.html template in the theme."
msgstr "Не удалось найти шаблон index.html в теме."

#: checks/class-fse-required-files-check.php:41
msgid "Could not find the file theme.json in the theme."
msgstr "Не удалось найти файл theme.json в теме."

#: checks/class-filesystem-http-check.php:52
#: checks/class-filesystem-http-check.php:86
msgid "%1$s was found in the file %2$s. %3$s."
msgstr "%1$s найден в файле %2$s. %3$s."

#: main.php:154
msgid "Theme Check is maintained by %s."
msgstr "Theme Check поддерживается %s."

#: main.php:92
msgid "Running %1$s tests against %2$s."
msgstr "Выполнение %1$s тестов против %2$s."

#: checks/class-version-tested-check.php:59
msgid "<strong>Tested up to</strong> is recommended to have major versions only (e.g. 5.8). Patch version is not needed (e.g. 5.8.1)."
msgstr "<strong>Проверено до</strong> Рекомендуется использовать только основные версии (например, 5.8). Патч-версия не нужна (например, 5.8.1)."

#: checks/class-version-php-check.php:55
msgid "<strong>Requires PHP</strong> is recommended to have major and minor versions only (e.g. 7.4). Patch version is not needed (e.g. 7.4.1)."
msgstr "<strong>Требуется PHP</strong> Рекомендуется иметь только основные и дополнительные версии (например, 7.4). Патч-версия не нужна (например, 7.4.1)."

#: checks/class-title-check.php:64
msgid "<strong>&lt;title&gt;</strong> tag was found in the file %1$s. Document titles must not be hard coded, use <strong>add_theme_support( \"title-tag\" )</strong> instead"
msgstr "<strong>&lt;title&gt;</strong> тег найден в файле %1$s. Названия документов не должны быть жестко закодированы, используйте <strong>add_theme_support( \"title-tag\" )</strong> вместо этого"

#: checks/class-title-check.php:45
msgid "<strong>wp_title()</strong> was found in the file %1$s. wp_title was historically used for the document &lt;title&gt; tag and was never intended for other purposes. Use <strong>add_theme_support( \"title-tag\" )</strong> instead"
msgstr "<strong>wp_title()</strong> найден в %1$s. wp_title исторически использовался для тега документа &lt;title&gt; и никогда не предназначался для других целей. Используйте <strong>add_theme_support( \"title-tag\" )</strong> вместо этого"

#: checks/class-textdomain-check.php:180
msgid "Found a translation function that is missing a text-domain in the file %1$s. Function %2$s, with the arguments %3$s. %4$s"
msgstr "Найдена функция перевода, в которой отсутствует текстовый домен в файле %1$s. Функция %2$s, с аргументами %3$s. %4$s"

#: checks/class-textdomain-check.php:134
msgid "Found a translation function that has an incorrect number of arguments in the file %1$s. Function %2$s, with the arguments %3$s. %4$s"
msgstr "Найдена функция перевода, которая имеет неправильное количество аргументов в файле %1$s. Функция %2$s, с аргументами %3$s. %4$s"

#: checks/class-script-tag-check.php:43
msgid "Found a script tag in %s. Scripts and styles need to be enqueued or added via a hook, otherwise it is more difficult to remove or replace them with plugins or child themes."
msgstr "Найден тег script в %s. Скрипты и стили должны вызываться или добавляться через хук, иначе их будет сложнее удалить или заменить плагинами или дочерними темами."

#: checks/class-plugin-territory-check.php:128
msgid "The theme uses <strong>remove_action %1$s %2$s</strong> in the file %3$s. This is plugin-territory functionality and must not be used in themes. Use a plugin instead. %4$s"
msgstr "Тема использует <strong>remove_action %1$s %2$s</strong> в файле %3$s. Это функциональность плагина, и она не должна использоваться в темах. Вместо этого используйте плагин. %4$s"

#: checks/class-plugin-territory-check.php:106
msgid "The theme uses the %1$s %2$s in the file %3$s. This is plugin-territory functionality and must not be used in themes. Use a plugin instead. %4$s"
msgstr "Тема использует %1$s %2$s в файле %3$s. Это функциональность плагина, и она не должна использоваться в темах. Вместо этого используйте плагин. %4$s"

#: checks/class-plugin-territory-check.php:86
msgid "The theme uses the %1$s function in the file %2$s. %1$s is plugin-territory functionality and must not be used in themes. Use a plugin instead. %3$s"
msgstr "Тема использует %1$s функцию в файле %2$s. %1$s - функциональность плагина, и она не должна использоваться в темах. Вместо этого используйте плагин. %3$s"

#. translators: %1$s file name. %2$s file size.
#: checks/class-image-size-check.php:48
msgid "%1$s is %2$s in size. Large file sizes have a negative impact on website performance and loading time. Compress images before using them."
msgstr "%1$s имеет размер %2$s. Большие размеры файлов негативно влияют на производительность сайта и время загрузки. Сжимайте изображения перед их использованием."

#: checks/class-i18n-check.php:73
msgid "Possible variable %1$s found in translation function in %2$s. Translation function calls must not contain PHP variables, use placeholders instead. See <a href=\"%3$s\" target=\"_blank\">Internationalization Guidelines (Opens in a new window)</a>. %4$s"
msgstr "Возможная переменная %1$s найдена в функции перевода в %2$s. Вызовы функций перевода не должны содержать переменные PHP, вместо них используйте заполнители. Смотрите <a href=\"%3$s\" target=\"_blank\">Руководство по интернационализации (Откроется в новом окне)</a>. %4$s"

#: checks/class-generated-check.php:55
msgid "This theme appears to have been auto-generated."
msgstr "Похоже, что эта тема была сгенерирована автоматически."

#: checks/class-filesystem-http-check.php:68
msgid "Theme Check is not able to determine if WP_Filesystem is used correctly. WP_Filesystem should only be used for theme upgrade operations, not for all file operations. Before continuing, you must manually review the code. Consider using file_get_contents(), scandir(), or glob(). It is not recommended to make changes to third-party frameworks that use WP_Filesystem, for example, TGMPA"
msgstr "Theme Check не может определить, правильно ли используется WP_Filesystem. WP_Filesystem должна использоваться только для операций обновления темы, а не для всех файловых операций. Прежде чем продолжить, вы должны вручную просмотреть код. Рассмотрите возможность использования file_get_contents(), scandir() или glob(). Не рекомендуется вносить изменения в сторонние фреймворки, использующие WP_Filesystem, например, TGMPA"

#: checks/class-file-check.php:105
msgid "%1$s %2$s found. This file must not be in the production version of the theme."
msgstr "%1$s %2$s найден. Этот файл не должен находиться в рабочей версии темы."

#: checks/class-copyright-notice-check.php:58
msgid "Learn how to add a copyright notice (opens in a new window)."
msgstr "Узнайте, как добавить уведомление об авторских правах ( откроется в новом окне)."

#: checks/class-copyright-notice-check.php:57
msgid "Could not find a copyright notice for the theme. A copyright notice is needed if your theme is licenced as GPL."
msgstr "Не удалось найти уведомление об авторских правах для темы. Уведомление об авторских правах необходимо, если ваша тема лицензирована как GPL."

#: checks/class-deregister-check.php:29
msgid "Found wp_deregister_script in %1$s. Themes must not deregister scripts that are included in WordPress. Deregistering third party scripts that are registered by parent themes is allowed."
msgstr "Найден wp_deregister_script в %1$s. Темы не должны отменять регистрацию скриптов, включенных в WordPress. Разрешена отмена регистрации сторонних скриптов, зарегистрированных родительскими темами."

#: checks/class-line-endings-check.php:36
msgid "Both DOS and UNIX style line endings were found in the file %s. This causes a problem with SVN repositories and must be corrected before the theme can be accepted. Please change the file to use only one style of line endings."
msgstr "В файле %s были обнаружены окончания строк в стиле DOS и UNIX. Это вызывает проблемы с SVN-репозиториями и должно быть исправлено до того, как тема будет принята. Пожалуйста, измените файл, чтобы использовать только один стиль окончания строк."

#: checks/class-uri-check.php:53
msgid "Using a WordPress.org Theme URI is reserved for default and bundled themes (Twenty * series)."
msgstr "Использование URI темы WordPress.org зарезервировано для стандартных и связанных тем (серия Twenty *)."

#: checks/class-theme-support-check.php:37
msgid "No reference to <strong>add_theme_support( \"wp-block-styles\" )</strong> was found in the theme. It is recommended that the theme implement this functionality."
msgstr "В теме не найдено <strong>add_theme_support(\"wp-block-styles\" )</strong>. Рекомендуется, чтобы в теме была реализована эта функциональность."

#: checks/class-theme-support-check.php:36
msgid "No reference to <strong>add_theme_support( \"align-wide\" )</strong> was found in the theme. It is recommended that the theme implement this functionality."
msgstr "В теме не найдено <strong>add_theme_support(\"align-wide\" )</strong>. Рекомендуется, чтобы в теме была реализована эта функциональность"

#: checks/class-theme-support-check.php:35
msgid "No reference to <strong>add_theme_support( \"responsive-embeds\" )</strong> was found in the theme. It is recommended that the theme implement this functionality."
msgstr "В теме не найдено <strong>add_theme_support(\"responsive-embeds\" )</strong>. Рекомендуется, чтобы в теме была реализована эта функциональность."

#: checks/class-theme-support-check.php:34
msgid "No reference to <strong>add_theme_support( \"html5\", $args )</strong> was found in the theme. It is strongly recommended that the theme implement this functionality."
msgstr "В теме не найдено <strong>add_theme_support( \"html5\", $args )</strong>. Настоятельно рекомендуется, чтобы в теме была реализована эта функциональность."

#: checks/class-theme-support-check.php:33
msgid "No reference to <strong>add_theme_support( \"custom-logo\", $args )</strong> was found in the theme. It is recommended that the theme implement this functionality."
msgstr "В теме не найдено <strong>add_theme_support( \"custom-logo\", $args )</strong>. Рекомендуется, чтобы в теме была реализована эта функциональность."

#: checks/class-screen-reader-text-check.php:31
msgid "<strong>.screen-reader-text</strong> CSS class is generated by WordPress and needs to be styled with your theme CSS. See <a href=\"http://codex.wordpress.org/CSS#WordPress_Generated_Classes\">the Codex</a> for an example implementation."
msgstr "CSS-класс <strong>.screen-reader-text</strong> создается WordPress и должен быть оформлен с помощью CSS вашей темы. Пример реализации см. в <a href=\"http://codex.wordpress.org/CSS#WordPress_Generated_Classes\">Кодексе</a>."

#: checks/class-search-form-check.php:66
msgid "Use <strong>get_search_form()</strong> instead of hard coding forms. Otherwise, the form can not be filtered."
msgstr "Используйте <strong>get_search_form()</strong> вместо жесткого кодирования форм. В противном случае форма не сможет быть отфильтрована."

#: checks/class-search-form-check.php:64
msgid "<strong>role=\"search\"</strong> was found in %1$s. %2$s"
msgstr "<strong>role=\"search\"</strong> найдено в %1$s. %2$s"

#: checks/class-search-form-check.php:40
msgid "<strong>searchform.php</strong> was found in %1$s. %2$s"
msgstr "<strong>searchform.php</strong> найдено в %1$s. %2$s"

#: checks/class-search-form-check.php:28
msgid "Use <strong>get_search_form()</strong> instead of including searchform.php directly. Otherwise, the form can not be filtered."
msgstr "Используйте <strong>get_search_form()</strong> вместо того, чтобы включать searchform.php напрямую. В противном случае форма не сможет быть отфильтрована."

#: checks/class-bad-things-check.php:89
msgid "Found <strong>%1$s</strong> in the file <strong>%2$s</strong>."
msgstr "Найдено <strong>%1$s</strong> в файле <strong>%2$s</strong>."

#: checks/class-bad-things-check.php:61
msgid "Found %1$s in the file %2$s."
msgstr "Найдено %1$s в %2$s."

#: checks/class-filesystem-http-check.php:33
msgid "HTTP requests should be made using the WordPress HTTP wrappers, such as wp_safe_remote_get() and wp_safe_remote_post()"
msgstr "HTTP-запросы должны выполняться с использованием HTTP-оберток WordPress, таких как wp_safe_remote_get() и wp_safe_remote_post()."

#: checks/class-filesystem-http-check.php:31
msgid "File write operations should are avoided unless necessary"
msgstr "Следует избегать операций записи в файл, если в этом нет необходимости."

#: checks/class-filesystem-http-check.php:30
msgid "File read operations should use file_get_contents() but are discouraged unless required"
msgstr "Операции чтения файлов должны использовать функцию file_get_contents(), но не рекомендуется, если это не требуется"

#: checks/class-block-patterns-check.php:45
msgid "No reference to <strong>register_block_style</strong> was found in the theme. Theme authors are encouraged to implement new block styles as a transition to block themes."
msgstr "В теме не найдено упоминания <strong>register_block_style</strong>. Авторам тем рекомендуется внедрять новые стили блоков в качестве перехода к блочным темам."

#: checks/class-block-patterns-check.php:37
msgid "No reference to <strong>register_block_pattern</strong> was found in the theme. Theme authors are encouraged to implement custom block patterns as a transition to block themes."
msgstr "В теме не найдено <strong>register_block_pattern</strong>. Авторам тем рекомендуется внедрять пользовательские блочные паттерны в качестве перехода к блочным темам."

#: checks/class-underscores-check.php:56
msgid "Found a copy of Underscores. Using underscores.me as Theme URI or Author URI is not allowed. Update the files for your own theme."
msgstr "Найдена копия Underscores. Использование underscores.me в качестве URI темы или URI автора запрещено. Обновите файлы для своей собственной темы."

